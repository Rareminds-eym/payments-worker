# Local secrets for wrangler dev — copy this to .dev.vars and fill in your values.
# .dev.vars is gitignored and never deployed.

# Service JWT secret — must match the secret used by Pages Functions to sign JWTs
RAZORPAY_SERVICE_SECRET=your_service_jwt_secret

# Razorpay keys — use test keys (rzp_test_...) for local dev
RAZORPAY_KEY_ID=rzp_test_RNNqYdwXmbBzxz
RAZORPAY_KEY_SECRET=zUYP3rpWcSObKLIrVkPrm94p
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Environment (overrides wrangler.toml default of "production" during local dev)
ENVIRONMENT=development
